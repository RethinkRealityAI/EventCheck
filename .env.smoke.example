# Copy this file to .env.smoke and fill in the values. The .env.smoke
# file is gitignored; this .example is checked in as the template.
#
# These are PUBLIC anon keys — they're already exposed in every Netlify-
# built bundle (VITE_SUPABASE_ANON_KEY). They're scoped by RLS on the
# server. Keeping them out of the repo is just hygiene, not secrecy.
#
# To fill in: open the Supabase dashboard for each project →
# Settings → API → "Project URL" and "anon public" key.

SCAGO_SUPABASE_URL=https://iigbgbgakevcgilucvbs.supabase.co
SCAGO_SUPABASE_ANON_KEY=

GANSID_SUPABASE_URL=https://gticuvgclbvhwvpzkuez.supabase.co
GANSID_SUPABASE_ANON_KEY=
